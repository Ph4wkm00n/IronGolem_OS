# IronGolem OS Configuration
# Copy this file to .env and customize

# Deployment mode: solo, household, team
IRONGOLEM_MODE=solo

# Database (solo/household mode)
IRONGOLEM_DB_PATH=./data/irongolem.db

# Database (team mode - PostgreSQL)
# IRONGOLEM_PG_HOST=localhost
# IRONGOLEM_PG_PORT=5432
# IRONGOLEM_PG_USER=irongolem
# IRONGOLEM_PG_PASSWORD=changeme
# IRONGOLEM_PG_DATABASE=irongolem

# Service ports
IRONGOLEM_GATEWAY_PORT=8080
IRONGOLEM_SCHEDULER_PORT=8081
IRONGOLEM_HEALTH_PORT=8082
IRONGOLEM_DEFENSE_PORT=8083
IRONGOLEM_WEB_PORT=3000

# Logging
IRONGOLEM_LOG_LEVEL=info

# LLM Provider (configure at least one)
# IRONGOLEM_ANTHROPIC_API_KEY=
# IRONGOLEM_OPENAI_API_KEY=

# Telemetry (optional)
# IRONGOLEM_OTLP_ENDPOINT=http://localhost:4317
